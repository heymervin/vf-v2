# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ─── Resend ──────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_<key>
# Full sender address (not just domain). Must be verified in Resend.
EMAIL_FROM_ADDRESS=hello@mail.venueflow.io

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_<key>
STRIPE_WEBHOOK_SECRET=whsec_<secret>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_<key>

# ─── Inngest ─────────────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=<event-key>
INNGEST_SIGNING_KEY=signkey-<signing-key>
# Set to 1 for local dev to route jobs through the Inngest Dev Server.
# Do NOT set in hosted/cloud deployments.
# INNGEST_DEV=1

# ─── App ─────────────────────────────────────────────────────────────────────
# Must be set per environment — brochure email links and the embed snippet use
# this value. Locally: http://localhost:3000. On Vercel: your preview URL.
NEXT_PUBLIC_APP_URL=https://venueflow.io
